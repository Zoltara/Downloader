{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "framework": "vite",
  "devCommand": "npm run dev",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 300,
      "includeFiles": "api/bin/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ]
}